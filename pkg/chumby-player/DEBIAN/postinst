#!/bin/sh
set -e

if [ "$1" = "configure" ]; then
    # The state dir, owned by the service user before the service ever
    # runs — so chumby-download-firmware / chumby-local-widgets work
    # right after install, no sudo needed (StateDirectory= re-asserts
    # this ownership at every service start).
    if getent passwd pi >/dev/null 2>&1; then
        install -d -o pi -g pi /var/lib/chumby
    fi
    systemctl daemon-reload || true
    # reenable, not enable: drops the stale graphical.target.wants
    # symlink from installs before 0.8.5 (WantedBy changed).
    systemctl reenable chumby-player.service || true
    udevadm control --reload-rules || true
    udevadm trigger --subsystem-match=input || true
    # re-run the USB-music rule for a stick that is already inserted
    udevadm trigger --subsystem-match=block --action=add || true
    # re-run the backlight rule for a display that is already up
    udevadm trigger --subsystem-match=backlight --action=add || true
    # First-run guidance, derived from live state — the apt transcript is
    # the one place a fresh installer surely reads. Quiet on upgrades
    # where display and firmware are already in place.
    have_swf=no
    if [ -e /var/lib/chumby/controlpanel.swf ] \
        || [ -e /usr/share/chumby-player/swf/controlpanel.swf ]; then
        have_swf=yes
    fi
    have_tft=no
    for card in /dev/dri/by-path/platform-*.spi-cs-*-card; do
        if [ -e "$card" ]; then have_tft=yes; break; fi
    done

    if [ "$have_tft" = no ] || [ "$have_swf" = no ]; then
        echo "" >&2
        echo "chumby-player: to get to a running panel:" >&2
    fi
    if [ "$have_tft" = no ]; then
        # HDMI and DSI displays need nothing: the firmware detects them
        # and the kiosk uses them as found. Only an SPI panel needs the
        # owner to declare it — so say which situation this machine is in.
        if ls /dev/dri/card* >/dev/null 2>&1; then
            cat >&2 <<'EOF'
  * No SPI TFT found — the kiosk will use the display you have (HDMI
    and DSI need no configuration). Fitting a piscreen-class 3.5" SPI
    panel instead? Append to /boot/firmware/config.txt and reboot:
        dtparam=spi=on
        dtoverlay=piscreen,speed=24000000,rotate=0,drm,swapxy=on,invy=on
    Vendor fbtft overlays (e.g. waveshare35b-v2) will NOT work — the
    kiosk needs a DRM device.
EOF
        else
            cat >&2 <<'EOF'
  * No display (DRM) device present. HDMI and DSI displays need no
    configuration; for a piscreen-class 3.5" SPI panel, append to
    /boot/firmware/config.txt and reboot:
        dtparam=spi=on
        dtoverlay=piscreen,speed=24000000,rotate=0,drm,swapxy=on,invy=on
    Vendor fbtft overlays (e.g. waveshare35b-v2) will NOT work — the
    kiosk needs a DRM device.
EOF
        fi
    fi
    if [ "$have_swf" = no ]; then
        cat >&2 <<'EOF'
  * controlpanel.swf is copyrighted chumby firmware and not included.
    Run  chumby-download-firmware  to fetch it — plus the intro and
    alarm tones — from Chumby's servers, or copy the files from your
    chumby or its backup into /var/lib/chumby.
EOF
    fi
    # Optional: a physical power button. Can't detect wiring from software,
    # so this is offered every install that lacks the overlay, not gated
    # on any other check. GPIO3 is the only pin the SoC can wake a halted
    # Pi from (firmware feature, no overlay needed for that half) — the
    # overlay only adds the clean-shutdown-on-press side, and its default
    # gpio_pin is already 3.
    if ! grep -q '^dtoverlay=gpio-shutdown' /boot/firmware/config.txt 2>/dev/null; then
        cat >&2 <<'EOF'

chumby-player: optional — a button between GPIO3 (physical pin 5) and a
  GND pin (e.g. pin 6) gives a clean shutdown/wake power button; the Pi
  can already power back on from a GPIO3 short with no configuration,
  but shutdown-on-press needs a line APPENDED to
  /boot/firmware/config.txt (at the end — after [all]; inside an
  earlier [pi*] section it silently does nothing):
    dtoverlay=gpio-shutdown
EOF
    fi
    echo "" >&2
    echo "chumby-player: enabled for next boot; start now with:" >&2
    echo "  sudo systemctl start chumby-player" >&2
fi
