#!/usr/bin/env python3
"""chumby-local-widgets — put your own widgets into the channel.

Scans a widgets folder and writes the local profile.xml the control
panel merges into its channel on the next start (fork design §3).
"""

import argparse
import os
import subprocess
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

STATE = Path(os.environ.get("CHUMBY_STATE", "/var/lib/chumby"))
DEFAULT_WIDGETS = STATE / "widgets"
DEFAULT_PROFILE = STATE / "fixtures/rootfs/psp/profile.xml"

THUMB_SUFFIXES = (".jpg", ".jpeg", ".png")
# Above the static channel's instance ids, which start at 1.
ID_BASE = 1000

HOW_TO = """\
How to add a widget:
  Put its .swf into the widgets folder — the filename becomes the widget
  name. A .jpg/.png with the same name becomes the dashboard preview.
  Then re-run this script and restart the player.

Keeping a widget the player downloaded from chumby.com:
  The download cache is {cache}.
  It stores each downloaded widget movie under its opaque widget id (a
  GUID on a real chumby), and its widgetcache.xml records only
  id/version/size/md5 — no names, no preview images. Play the widget to
  figure out which file is which, then copy it here under a real name:
      cp {cache}/<id> {widgets}/'My Widget.swf'
  There is no cached preview image; add your own .jpg/.png if you want one.
"""


def instance(idx: int, swf: Path) -> ET.Element:
    inst = ET.Element("widget_instance", id=str(ID_BASE + idx))
    ET.SubElement(inst, "name").text = swf.stem
    widget = ET.SubElement(inst, "widget", id=str(ID_BASE + idx))
    ET.SubElement(widget, "name").text = swf.stem
    ET.SubElement(widget, "description").text = f"Local widget ({swf.name})"
    ET.SubElement(widget, "version").text = "1.0"
    ET.SubElement(widget, "mode", mode="timeout", time="86400")
    ET.SubElement(widget, "access", sendable="false", deleteable="false",
                  access="private", virtualable="false")
    ET.SubElement(widget, "movie", href=swf.resolve().as_uri(),
                  contenttype="application/x-shockwave-flash")
    thumb = find_thumb(swf)
    if thumb:
        ET.SubElement(widget, "thumbnail", href=thumb.resolve().as_uri(),
                      contenttype=f"image/{thumb.suffix.lstrip('.')}")
    ET.SubElement(inst, "access", access="private")
    ET.SubElement(inst, "mode", mode="timeout", time="86400")
    ET.SubElement(inst, "widget_parameters")
    return inst


def find_thumb(swf: Path) -> Path | None:
    for suffix in THUMB_SUFFIXES:
        thumb = swf.with_suffix(suffix)
        if thumb.is_file():
            return thumb
    return None


def confirm(prompt: str) -> bool:
    try:
        answer = input(f"{prompt} [Y/n] ").strip().lower()
    except EOFError:
        return False
    return answer in ("", "y", "yes")


def main() -> None:
    parser = argparse.ArgumentParser(
        description=__doc__,
        epilog=HOW_TO.format(cache=STATE / "fixtures/rootfs/tmp/widgetcache",
                             widgets=DEFAULT_WIDGETS),
        formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("widgets_dir", nargs="?", type=Path,
                        default=DEFAULT_WIDGETS,
                        help=f"folder holding your .swf widgets (default: {DEFAULT_WIDGETS})")
    parser.add_argument("profile", nargs="?", type=Path,
                        default=DEFAULT_PROFILE,
                        help=f"profile.xml to write (default: {DEFAULT_PROFILE})")
    args = parser.parse_args()

    print(f"Widgets folder:  {args.widgets_dir}")
    print(f"Local profile:   {args.profile}")
    print()

    # On a box whose service has never run, the fixtures tree the profile
    # lives in does not exist yet — seed it the launcher's way rather
    # than crash (or mkdir a fragment that would block the real seeding).
    if args.profile == DEFAULT_PROFILE and not args.profile.parent.is_dir():
        print("Fixtures not seeded yet — preparing them (chumby-player-run --seed).")
        subprocess.run(["chumby-player-run", "--seed"], check=False)
    if not args.profile.parent.is_dir():
        sys.exit(f"{args.profile.parent} does not exist — start the player "
                 "once (sudo systemctl start chumby-player) and re-run.")

    swfs = sorted((p for p in args.widgets_dir.glob("*.swf") if p.is_file()),
                  key=lambda p: p.name.lower())
    if not swfs:
        print(f"No .swf widgets found in {args.widgets_dir}.")
        if args.profile.is_file():
            print(f"{args.profile} left untouched — delete it to clear the local widgets.")
        print()
        print(HOW_TO.format(cache=STATE / "fixtures/rootfs/tmp/widgetcache",
                            widgets=args.widgets_dir))
        return

    print(f"Found {len(swfs)} widget(s):")
    for idx, swf in enumerate(swfs):
        thumb = find_thumb(swf)
        preview = f"preview {thumb.name}" if thumb else "no preview image"
        print(f"  {ID_BASE + idx}  {swf.stem}  ({preview})")
    print()

    if args.profile.is_file() and not confirm(f"{args.profile} exists — overwrite?"):
        raise SystemExit("Aborted, nothing written.")

    profile = ET.Element("profile", id="1")
    instances = ET.SubElement(profile, "widget_instances")
    for idx, swf in enumerate(swfs):
        instances.append(instance(idx, swf))
    ET.indent(profile)

    tmp = args.profile.with_name(args.profile.name + ".new")
    ET.ElementTree(profile).write(tmp, encoding="UTF-8", xml_declaration=True)
    tmp.replace(args.profile)
    print(f"Wrote {args.profile}.")
    print("Restart the player to load it:  sudo systemctl restart chumby-player")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit("\nAborted, nothing written.")
