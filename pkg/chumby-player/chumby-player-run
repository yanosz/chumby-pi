#!/bin/sh
# chumby-player-run — seed state and launch the chumby control panel.
#
# Normally exec'd by cage from chumby-player.service; also works
# standalone inside any Wayland session for debugging.
#
# The copyrighted chumby firmware files are never packaged; the owner
# copies them from a chumby or its backup into /var/lib/chumby:
#   controlpanel.swf  from /usr/widgets/controlpanel.swf     required
#   widgets/*.swf     from /usr/widgets/ (+ .jpg previews),  optional —
#                     then run chumby-local-widgets
#   alarmtones/*.mp3  from /usr/chumby/alarmtones/           optional
#                     (stock filenames — the panel hardcodes them)
#   intro.swf         from /usr/widgets/intro.swf            optional
#
# Overrides (set in /etc/default/chumby-player for the service; the
# last two exist so a dev box can drive this script against a staged
# tree and its own player build):
#   CHUMBY_STATE         state dir      (default /var/lib/chumby)
#   CHUMBY_SWF           control panel SWF (default: see above)
#   CHUMBY_CTL           control FIFO   (default /tmp/chumby-ctl)
#   CHUMBY_AUDIO_DEVICE  mpv audio device (default: PipeWire default sink)
#   RUST_LOG             log filter     (default warn; use
#                        warn,chumby_host=info,avm_trace=info to debug)
#   CHUMBY_SHARE         installed data (default /usr/share/chumby-player)
#   CHUMBY_RUFFLE        player binary  (default
#                        /usr/lib/chumby-player/ruffle_desktop)

set -eu

SHARE="${CHUMBY_SHARE:-/usr/share/chumby-player}"
STATE="${CHUMBY_STATE:-/var/lib/chumby}"
CTL="${CHUMBY_CTL:-/tmp/chumby-ctl}"
RUFFLE="${CHUMBY_RUFFLE:-/usr/lib/chumby-player/ruffle_desktop}"

# controlpanel.swf: owner copy first; the /usr/share path still serves
# boxes that installed the retired data deb. Checks readability, not
# just existence — a sudo cp leaves a root-only file the pi user can
# stat but not open, and the player then shows a blank white screen.
check_swf() {
    SWF="${CHUMBY_SWF:-}"
    if [ -z "$SWF" ]; then
        for c in "$STATE/controlpanel.swf" "$SHARE/swf/controlpanel.swf"; do
            if [ -e "$c" ]; then SWF="$c"; break; fi
        done
    fi
    if [ -z "$SWF" ] || [ ! -e "$SWF" ]; then
        cat >&2 <<EOF
chumby-player: controlpanel.swf not found. It is copyrighted chumby
firmware and not distributed with this package. Copy it from your
chumby or its backup (on the device: /usr/widgets/controlpanel.swf) to:
    $STATE/controlpanel.swf
Optional, same sources: widget SWFs into $STATE/widgets (then run
chumby-local-widgets), /usr/chumby/alarmtones/*.mp3 into
$STATE/alarmtones, /usr/widgets/intro.swf to $STATE/intro.swf.
No backup at hand? chumby-download-firmware fetches the control panel
and a clock widget from chumby.com (intro and tones stay backup-only).
EOF
        return 1
    fi
    if [ ! -r "$SWF" ]; then
        cat >&2 <<EOF
chumby-player: $SWF exists but is not readable by user $(id -un).
(sudo cp keeps the source's root-only permissions.) Fix with:
    sudo chown pi:pi $SWF && sudo chmod 644 $SWF
EOF
        return 1
    fi
}

# The intro is optional, so an unreadable copy only warns.
warn_unreadable_intro() {
    if [ -e "$1" ] && [ ! -r "$1" ]; then
        echo "chumby-player: $1 is not readable by user $(id -un)" \
             "(sudo chmod 644 it) — skipping the intro." >&2
        return 1
    fi
}

# --check: same verdict as a real start, but printable before cage
# runs — the service uses it as ExecStartPre so a missing/unreadable
# SWF shows up in "systemctl status chumby-player" even when the
# compositor itself cannot start (no DRM device, wrong overlay).
if [ "${1:-}" = "--check" ]; then
    check_swf || exit 1
    warn_unreadable_intro "$STATE/intro.swf" || true
    exit 0
fi

# First run: seed the writable fixture tree. The panel writes into
# fixtures/rootfs (alarms, streams, volume — all /psp settings), so it
# cannot run from /usr/share. Remove "$STATE/fixtures" to re-seed after
# a chumby-player upgrade (this discards those panel-made settings).
if [ ! -d "$STATE/fixtures" ]; then
    mkdir -p "$STATE"
    cp -a "$SHARE/fixtures" "$STATE/fixtures.seed"
    mv "$STATE/fixtures.seed" "$STATE/fixtures"
fi

# The panel browses /mnt/usb (My Music Files). On the device that must
# be the real stick, not the demo tones the fixtures carry for desktop
# and CI runs: replace the seeded directory with a symlink to the
# read-only automount (99-chumby-usb-music.rules + chumby-usb-mount@).
# Idempotent, so an upgrade re-seed gets converted again.
USB_LINK="$STATE/fixtures/rootfs/mnt/usb"
if [ ! -L "$USB_LINK" ]; then
    rm -rf "$USB_LINK"
    mkdir -p "${USB_LINK%/*}"
    ln -s /media/chumby-usb "$USB_LINK"
fi

# Alarm tones are owner-supplied. Point the fixture path at the owner
# folder — unless a tree seeded by the retired data deb already carries
# real tones, which keeps working until its owner deletes them.
TONES="$STATE/fixtures/rootfs/usr/chumby/alarmtones"
if [ ! -L "$TONES" ] && ! ls "$TONES"/*.mp3 >/dev/null 2>&1; then
    rm -rf "$TONES"
    mkdir -p "${TONES%/*}" "$STATE/alarmtones"
    ln -s "$STATE/alarmtones" "$TONES"
fi

# The in-panel INTRO button plays the rootfs /usr/widgets/intro.swf;
# expose the owner copy there. Deliberately dangling until the owner
# copies the file — the player treats a dangling link as absent and
# keeps the button disabled (fork ui-policy info-intro). A real file
# from a data-deb-seeded tree wins and is left alone.
INTRO_LINK="$STATE/fixtures/rootfs/usr/widgets/intro.swf"
if [ -L "$INTRO_LINK" ] || [ ! -e "$INTRO_LINK" ]; then
    mkdir -p "${INTRO_LINK%/*}"
    ln -sfn "$STATE/intro.swf" "$INTRO_LINK"
fi

# Owner config (volume cap, chumby.com access — fork FR14/FR15). The
# player reads <fixtures>/player.toml once at start; the real file is a
# dpkg conffile in /etc, so edits survive upgrades and fixture re-seeds.
ln -sf /etc/chumby-player/player.toml "$STATE/fixtures/player.toml"

[ -p "$CTL" ] || mkfifo -m 600 "$CTL"

# Owner widgets ride the panel's native local-profile merge; the
# user-run chumby-local-widgets helper writes /psp/profile.xml from this
# folder. Here only make sure the folder exists to be found.
mkdir -p "$STATE/widgets"

export RUST_LOG="${RUST_LOG:-warn}"

# lavapipe (software Vulkan) worker threads: extra workers roughly
# double total CPU for the same 12 fps output on the Pi 3B+ —
# measured 215% (4 threads) vs 103% (1 thread), see
# claude-docs/requirements.md NFR4.
export LP_NUM_THREADS="${LP_NUM_THREADS:-1}"

check_swf || exit 1

# Boot-time intro, as rcS's start_intro: the tour plays before the panel,
# every boot until its "never show again" button writes /psp/disable_intro
# (the enable/disable backticks are real in the player). It always quits
# itself — end of tour and both control-screen buttons fscommand("quit") —
# so this blocks only while the tour is on screen; a crash must not keep
# the panel from starting. start_intro's /mnt/usb/intro.swf override is
# deliberately not reproduced: a factory/debug hook, and auto-running a
# SWF off whatever stick is inserted is not a behavior to keep.
# Owner copy at $STATE/intro.swf; the fixtures path still serves trees
# seeded by the retired data deb.
INTRO="$STATE/intro.swf"
warn_unreadable_intro "$INTRO" || INTRO=""
[ -f "$INTRO" ] || INTRO="$STATE/fixtures/rootfs/usr/widgets/intro.swf"
if [ -f "$INTRO" ] && [ -r "$INTRO" ] && [ ! -e "$STATE/fixtures/rootfs/psp/disable_intro" ]; then
    "$RUFFLE" \
        --load-behavior blocking \
        --filesystem-access-mode allow \
        --chumby-fixtures "$STATE/fixtures" \
        --fullscreen \
        "$INTRO" || true
fi

exec "$RUFFLE" \
    --load-behavior blocking \
    --filesystem-access-mode allow \
    --chumby-fixtures "$STATE/fixtures" \
    --chumby-control "$CTL" \
    --fullscreen \
    -PlocalCache=1 \
    "$SWF"
