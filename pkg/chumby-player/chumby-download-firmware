#!/usr/bin/env python3
"""chumby-download-firmware — fetch the files the package cannot ship.

The control panel, intro tour and alarm tones are
copyrighted Chumby Industries firmware, so the Debian package does not
contain them. Chumby's own servers still do: the classic 1.7.3 firmware
image (update.zip, ~30 MB) carries everything but the newest control
panel, and chumby.com serves that panel through the same protocol the
original firmware's download_cp used. This helper shows exactly what it
would download and asks before touching the network. Nothing identifying
is sent (the device id in the control-panel query is zeroed), and the
player itself stays offline afterwards.
"""

import hashlib
import os
import shutil
import subprocess
import sys
import tempfile
import urllib.request
import xml.etree.ElementTree as ET
import zipfile
from pathlib import Path

STATE = Path(os.environ.get("CHUMBY_STATE", "/var/lib/chumby"))

UPDATE_URL = "https://files.chumby.com/resources/classic/1-7-3/update.zip"
UPDATE_MD5 = "3fa64d39777d27908586d51824bb0eb7"
# Inside the blob: a zip per partition; rfs1.bin is the CRAMFS rootfs.
RFS_MEMBER = "update2/rfs1.bin.zip"
RFS_NAME = "rfs1.bin"

# CRAMFS path in the 1.7.3 rootfs -> file under $STATE.
FIRMWARE_FILES = {
    "usr/widgets/intro.swf": "intro.swf",
    "usr/chumby/alarmtones/Beep.mp3": "alarmtones/Beep.mp3",
    "usr/chumby/alarmtones/Bugle.mp3": "alarmtones/Bugle.mp3",
    "usr/chumby/alarmtones/ClockStrikes.mp3": "alarmtones/ClockStrikes.mp3",
    "usr/chumby/alarmtones/Gong.mp3": "alarmtones/Gong.mp3",
    "usr/chumby/alarmtones/Klaxon.mp3": "alarmtones/Klaxon.mp3",
    "usr/chumby/alarmtones/Nightingale.mp3": "alarmtones/Nightingale.mp3",
    "usr/chumby/alarmtones/RoosterCrow.mp3": "alarmtones/RoosterCrow.mp3",
}
# The blob's own control panel — 2.8.75, older than the 2.8.87b3 this
# project is verified against. Fallback only (see download_controlpanel).
BLOB_CONTROLPANEL = "usr/widgets/controlpanel.swf"

# The panel-download protocol of the original firmware's download_cp
# script. Identity params are deliberately zero/static: the server
# ignores them and answers with the newest build for the platform.
CP_QUERY = ("https://www.chumby.com/xml/controlpanel"
            "?id=00000000-0000-0000-0000-000000000000"
            "&hw=3.8&sw=1.7.2&fw=1.7.2&lang=en-us")


def fetch(url: str, timeout: int = 300) -> bytes:
    with urllib.request.urlopen(url, timeout=timeout) as resp:
        return resp.read()


def confirm(prompt: str) -> bool:
    try:
        answer = input(f"{prompt} [Y/n] ").strip().lower()
    except EOFError:
        return False
    return answer in ("", "y", "yes")


def save(path: Path, data: bytes) -> None:
    # 0644 no matter the umask: the player runs as user pi and a
    # root-only file yields a blank screen (the 0.8.1 lesson).
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(path.name + ".new")
    tmp.write_bytes(data)
    tmp.chmod(0o644)
    tmp.replace(path)
    print(f"  wrote {path} ({len(data)} bytes)")


def sevenzip() -> str:
    for name in ("7zz", "7z", "7za"):
        if shutil.which(name):
            return name
    sys.exit("no 7-Zip binary found — install it with: sudo apt install 7zip")


def extract_rootfs(workdir: Path) -> Path | None:
    """Download update.zip, unpack the CRAMFS rootfs, return its tree."""
    missing = [t for t in FIRMWARE_FILES.values() if not (STATE / t).is_file()]
    if not missing:
        print("firmware files: all present, skipping update.zip.")
        return None

    print("The classic 1.7.3 firmware image provides intro.swf and the")
    print("alarm tones (a ~30 MB download):")
    print(f"  {UPDATE_URL}")
    if not confirm("Download it?"):
        print("  skipped.")
        return None

    blob = fetch(UPDATE_URL)
    if hashlib.md5(blob).hexdigest() != UPDATE_MD5:
        sys.exit(f"md5 mismatch (expected {UPDATE_MD5}) — not keeping the file.")
    blob_path = workdir / "update.zip"
    blob_path.write_bytes(blob)

    with zipfile.ZipFile(blob_path) as z:
        z.extract(RFS_MEMBER, workdir)
    with zipfile.ZipFile(workdir / RFS_MEMBER) as z:
        z.extract(RFS_NAME, workdir)

    # Only the two firmware directories: elsewhere the image's busybox
    # symlinks make 7-Zip exit nonzero ("dangerous link path").
    tree = workdir / "rootfs"
    subprocess.run([sevenzip(), "x", "-y", f"-o{tree}", str(workdir / RFS_NAME),
                    "usr/widgets", "usr/chumby/alarmtones"],
                   check=True, stdout=subprocess.DEVNULL)

    for src, target in FIRMWARE_FILES.items():
        dest = STATE / target
        if dest.is_file():
            print(f"  {dest} already present, kept.")
            continue
        save(dest, (tree / src).read_bytes())
    return tree


def download_controlpanel(rootfs: Path | None) -> None:
    target = STATE / "controlpanel.swf"
    if target.is_file():
        print(f"controlpanel.swf: already at {target}, skipping.")
        return

    print("controlpanel.swf: chumby.com serves the newest build (2.8.87b3),")
    print("the one this player is tested against — recommended.")
    try:
        meta = ET.fromstring(fetch(CP_QUERY, timeout=30))
        url = meta.findtext("url", "")
        md5 = meta.findtext("md5", "")
        build = meta.get("build", "?")
    except OSError as e:
        print(f"  chumby.com query failed ({e}).")
        url = md5 = ""
        build = "?"
    if url and md5:
        print(f"controlpanel.swf, build {build}:")
        print(f"  {url}")
        if confirm("Download it?"):
            data = fetch(url)
            if hashlib.md5(data).hexdigest() != md5:
                sys.exit(f"md5 mismatch (expected {md5}) — not keeping the file.")
            save(target, data)
            return
        print("  skipped.")

    # Last resort: the 1.7.3 image's own panel. Runs, but it is not the
    # build this project verifies against (claude-docs/development.md).
    if rootfs is not None:
        print("The firmware image carries an older panel (2.8.75). It works,")
        print("but this project is tested against 2.8.87b3 only.")
        if confirm("Use the 2.8.75 panel from the image instead?"):
            save(target, (rootfs / BLOB_CONTROLPANEL).read_bytes())


def main() -> None:
    print(__doc__)
    print(f"Files go to {STATE}.")
    if not os.access(STATE.parent, os.W_OK) and not STATE.is_dir():
        sys.exit(f"{STATE} does not exist and is not creatable — "
                 "install chumby-player first (or run with sudo once).")

    with tempfile.TemporaryDirectory(prefix="chumby-fw-") as tmp:
        rootfs = extract_rootfs(Path(tmp))
        print()
        download_controlpanel(rootfs)

    print()
    print("Widgets are optional — without any, the panel is a clock.")
    print("To add some, put .swf files (plus .jpg/.png previews) into")
    print(f"{STATE}/widgets — e.g. copied from a chumby backup's")
    print("/usr/widgets — then run chumby-local-widgets.")
    print()
    print("Start (or restart) the panel:  sudo systemctl restart chumby-player")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit("\nAborted.")
    except urllib.error.URLError as e:
        sys.exit(f"download failed: {e}")
