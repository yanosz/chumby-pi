# IDE state
.idea/

# Local-only investigation notes (device identities, GUIDs, anything
# tied to the user's own hardware) — never committed.
/claude-docs/private/

# Deb build staging and output (pkg/build-debs.sh)
/pkg/build/
/pkg/out/

# Copyrighted chumby material — never commit any of it. controlpanel.swf
# and other SWF assets belong in swf-assets/ (untracked) or come from your
# own chumby backup; alarm tones likewise. Widget preview thumbnails
# (fixtures/widgets/*.jpg) render chumby widget artwork — same posture as
# the widget SWFs they come from. The appendix is the decompiled panel.
*.swf
*.mp3
*.wav
/fixtures/widgets/*.jpg
/claude-docs/appendix/
/resources/zurks-offline-firmware-classic/

# chumby-widget-channel's change-detection cache (runtime state, not source;
# the committed profile + *.widget.xml sidecars are the source of truth).
/fixtures/widgets/.channel.sig

# Panel screenshots show chumby UI artwork — not published; use Nextcloud
# for test images.
/claude-docs/images/
