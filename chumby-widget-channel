#!/usr/bin/env python3
"""chumby-widget-channel — build the single local widget channel.

The control panel fetches its channel from /xml/profiles. This project
ships ONE channel = every installed widget. Instead of hand-maintaining
that profile, each widget carries an XML sidecar (fixtures/widgets/
<name>.widget.xml, the <widget> element the panel consumes); this script
enumerates them, wraps each in the <widget_instance>/<profile> envelope
ordered by widget id, and writes the profile plus currentProfileID/Name.

    chumby-widget-channel [--fixtures DIR] [--force] [--quiet]

Run at boot before the panel (via chumby-widget-channel.service) so an
added or removed widget appears in the channel; rewrites only when the
sidecar set changed (tracked in <fixtures>/widgets/.channel.sig).
--fixtures defaults to the tree next to this script (dev box); the Pi
service passes /var/lib/chumby/fixtures.

Design and rationale: claude-docs/reference/19-widget-channel.md.
"""

import argparse
import copy
import hashlib
import sys
import xml.etree.ElementTree as ET
from pathlib import Path

CHANNEL_ID = "1"
CHANNEL_NAME = "chumbypi-channel"
CHANNEL_USER = "jan"


def find_sidecars(widgets_dir: Path):
    """Every *.widget.xml in the widgets dir, parsed, ordered by widget id."""
    entries = []
    for path in sorted(widgets_dir.glob("*.widget.xml")):
        try:
            widget = ET.parse(path).getroot()
        except ET.ParseError as exc:
            raise SystemExit(f"{path}: malformed widget sidecar: {exc}")
        if widget.tag != "widget":
            raise SystemExit(
                f"{path}: root element is <{widget.tag}>, expected <widget>"
            )
        try:
            order = int(widget.get("id", ""))
        except ValueError:
            raise SystemExit(f"{path}: <widget> needs an integer id attribute")
        entries.append((order, path.name, widget))
    entries.sort(key=lambda e: (e[0], e[1]))
    return entries


def signature(entries) -> str:
    """Content hash of the ordered sidecar set (drives change detection)."""
    h = hashlib.sha256()
    for order, name, widget in entries:
        h.update(name.encode())
        h.update(b"\0")
        h.update(ET.tostring(widget))
        h.update(b"\0")
    return h.hexdigest()


def build_profile(entries) -> ET.Element:
    profile = ET.Element("profile", id=CHANNEL_ID)
    ET.SubElement(profile, "name").text = CHANNEL_NAME
    ET.SubElement(profile, "description")
    user = ET.SubElement(profile, "user", username=CHANNEL_USER)
    profiles = ET.SubElement(user, "profiles")
    ET.SubElement(
        profiles, "profile", unaccepted="0", name=CHANNEL_NAME, id=CHANNEL_ID
    )
    ET.SubElement(profile, "access", access="private", id=CHANNEL_ID)
    instances = ET.SubElement(profile, "widget_instances")

    for index, (_order, _name, widget) in enumerate(entries, start=1):
        instance = ET.SubElement(instances, "widget_instance", id=str(index))
        wname = widget.findtext("name", default="")
        ET.SubElement(instance, "name").text = wname
        instance.append(copy.deepcopy(widget))
        ET.SubElement(instance, "access", access="private")
        # Instance mode mirrors the widget's own, as the real profile does.
        mode = widget.find("mode")
        if mode is not None:
            instance.append(copy.deepcopy(mode))
        else:
            ET.SubElement(instance, "mode", mode="timeout", time="86400")
        ET.SubElement(instance, "widget_parameters")
    return profile


def serialize(profile: ET.Element) -> bytes:
    ET.indent(profile, space="  ")
    body = ET.tostring(profile, encoding="unicode")
    # ElementTree writes empty tags as "<x />"; the chumby profile style
    # (and every other fixture) is "<x/>". Match it so generated and
    # hand-written XML diff cleanly. Our attribute values never contain
    # the literal " />", so this is unambiguous.
    body = body.replace(" />", "/>")
    return ('<?xml version="1.0" encoding="UTF-8"?>\n' + body + "\n").encode("utf-8")


def write_if_changed(path: Path, data: bytes) -> bool:
    if path.exists() and path.read_bytes() == data:
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_bytes(data)
    return True


def main(argv=None) -> int:
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument(
        "--fixtures",
        type=Path,
        default=Path(__file__).resolve().parent / "fixtures",
        help="fixtures tree to read widgets from and write the profile into",
    )
    parser.add_argument(
        "--force", action="store_true", help="rewrite even if nothing changed"
    )
    parser.add_argument(
        "--quiet", action="store_true", help="only print on error"
    )
    args = parser.parse_args(argv)

    fixtures = args.fixtures.resolve()
    widgets_dir = fixtures / "widgets"
    if not widgets_dir.is_dir():
        print(f"no widgets dir at {widgets_dir}", file=sys.stderr)
        return 1

    profile_path = fixtures / "http" / "xml.chumby.com" / "xml" / "profiles"
    sig_path = widgets_dir / ".channel.sig"

    entries = find_sidecars(widgets_dir)
    if not entries:
        print(f"no *.widget.xml in {widgets_dir}", file=sys.stderr)
        return 1

    sig = signature(entries)
    old_sig = sig_path.read_text().strip() if sig_path.exists() else None
    if not args.force and sig == old_sig and profile_path.exists():
        if not args.quiet:
            names = ", ".join(w.findtext("name", "?") for _o, _n, w in entries)
            print(f"widget channel unchanged ({len(entries)} widgets: {names})")
        return 0

    data = serialize(build_profile(entries))
    changed = write_if_changed(profile_path, data)
    write_if_changed(fixtures / "rootfs" / "tmp" / "currentProfileID",
                     (CHANNEL_ID + "\n").encode())
    write_if_changed(fixtures / "rootfs" / "tmp" / "currentProfileName",
                     (CHANNEL_NAME + "\n").encode())
    sig_path.write_text(sig + "\n")

    if not args.quiet:
        names = ", ".join(w.findtext("name", "?") for _o, _n, w in entries)
        verb = "regenerated" if changed else "already current"
        print(f"widget channel {verb}: {len(entries)} widgets ({names}) -> {profile_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
